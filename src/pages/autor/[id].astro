---
import Layout from '../../layouts/Layout.astro';
import AudioPlayer from '../../components/AudioPlayer';
import { authors } from '../../data/content';

export function getStaticPaths() {
  return authors.map((a) => ({ params: { id: a.id }, props: { author: a } }));
}

const { author } = Astro.props;

const pdfs = author.generated.filter((m: any) => m.type === 'pdf');
const audios = author.generated.filter((m: any) => m.type === 'audio');
const videos = author.generated.filter((m: any) => m.type === 'video');
const images = author.generated.filter((m: any) => m.type === 'image');
---

<Layout title={author.fullName}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-stone-400 mb-8">
      <a href="/" class="hover:text-amber-700 transition-colors">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/#autores" class="hover:text-amber-700 transition-colors">Autores</a>
      <span class="mx-2">/</span>
      <span class="text-stone-600">{author.name}</span>
    </nav>

    <!-- Header -->
    <div class="flex items-start gap-6 mb-10">
      {author.image ? (
        <img
          src={author.image}
          alt={author.name}
          class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl object-cover border-2 border-stone-200 flex-shrink-0"
        />
      ) : (
        <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl bg-stone-200 flex items-center justify-center flex-shrink-0 text-stone-500 font-serif text-4xl font-bold">
          {author.name[0]}
        </div>
      )}
      <div>
        <h1 class="font-serif text-3xl sm:text-4xl font-bold text-stone-900">{author.fullName}</h1>
        <p class="text-stone-400 mt-1">{author.years}</p>
        <p class="mt-3 text-stone-600 leading-relaxed max-w-2xl">{author.bio}</p>
      </div>
    </div>

    <!-- Obras -->
    <section class="mb-12">
      <h2 class="font-serif text-2xl font-bold text-stone-900 mb-4">Textos fuente</h2>
      <div class="grid gap-3">
        {author.works.map((work: any) => (
          <a
            href={`/visor?file=${encodeURIComponent(work.path)}&title=${encodeURIComponent(work.title)}`}
            class="group flex items-center gap-3 bg-white rounded-lg border border-stone-200 p-4 hover:border-amber-300 hover:shadow-sm transition-all"
          >
            <div class="w-10 h-10 rounded-lg bg-red-50 text-red-600 flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
              <p class="font-medium text-stone-800 group-hover:text-amber-700 transition-colors">{work.title}</p>
              <p class="text-xs text-stone-400">Abrir en el visor</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Material generado -->
    {author.generated.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-stone-900 mb-4">Material generado</h2>

        {pdfs.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-3">Resumenes y presentaciones</h3>
            <div class="grid gap-3">
              {pdfs.map((m: any) => (
                <a
                  href={`/visor?file=${encodeURIComponent(m.path)}&title=${encodeURIComponent(m.title)}`}
                  class="group flex items-center gap-3 bg-white rounded-lg border border-stone-200 p-4 hover:border-amber-300 hover:shadow-sm transition-all"
                >
                  <div class="w-10 h-10 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center flex-shrink-0">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  </div>
                  <div>
                    <p class="font-medium text-stone-800 group-hover:text-amber-700 transition-colors">{m.title}</p>
                    <p class="text-xs text-stone-400">PDF — Abrir en el visor</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {audios.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-3">Audio</h3>
            <div class="grid gap-3">
              {audios.map((m: any) => (
                <AudioPlayer client:visible src={m.path} title={m.title} />
              ))}
            </div>
          </div>
        )}

        {videos.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-3">Video</h3>
            <div class="grid gap-3">
              {videos.map((m: any) => (
                <div class="bg-white rounded-lg border border-stone-200 p-4">
                  <p class="font-medium text-stone-800 mb-3">{m.title}</p>
                  <video controls class="w-full rounded-lg" preload="metadata">
                    <source src={m.path} type="video/mp4" />
                  </video>
                </div>
              ))}
            </div>
          </div>
        )}

        {images.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-3">Diagramas</h3>
            <div class="grid gap-3">
              {images.map((m: any) => (
                <div class="bg-white rounded-lg border border-stone-200 p-4">
                  <p class="font-medium text-stone-800 mb-3">{m.title}</p>
                  <img src={m.path} alt={m.title} class="w-full rounded-lg" loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        )}
      </section>
    )}
  </div>
</Layout>
