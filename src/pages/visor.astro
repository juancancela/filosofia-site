---
import Layout from '../layouts/Layout.astro';

const file = Astro.url.searchParams.get('file') || '';
const title = Astro.url.searchParams.get('title') || 'Documento';
---

<Layout title={title}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-stone-400 mb-4">
      <a href="/" class="hover:text-amber-700 transition-colors">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-stone-600">{title}</span>
    </nav>

    <div class="flex items-center justify-between mb-4">
      <h1 class="font-serif text-xl sm:text-2xl font-bold text-stone-900 truncate">{title}</h1>
      <a
        href={file}
        download
        class="flex-shrink-0 ml-4 inline-flex items-center gap-2 text-sm font-medium text-amber-700 hover:text-amber-800 bg-amber-50 hover:bg-amber-100 px-4 py-2 rounded-lg transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Descargar
      </a>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden" style="height: calc(100vh - 200px);">
      <iframe
        src={file}
        class="w-full h-full"
        title={title}
      />
    </div>
  </div>
</Layout>
